<MainNode name="whatever">
  <Drive>/home</Drive>
  <DeliveryPath>/Delivery</DeliveryPath>
  <DeliveryPathSubDirs>
    <DirItem name="/SubExampleA"/>
    <DirItem name="/SubExampleB"/>
  </DeliveryPathSubDirs>
  <DeleteIfExist>yes</DeleteIfExist>
  <CreateIfNotExist>yes</CreateIfNotExist>

 <BuildOutput path="/home/developer/PycharmProjects/pythonProject/CopyToDeliveryRepoGitHub/CopyToDeliveryExampleSource"/>

 <CopySet>
   <!-- Template of copy cases -->
   <!-- Known attributes: -->
     <!-- path="BuildOutput" -->
     <!-- path="full" -->
     <!-- file="rename" -->

   <!-- ************ Copy 2 specific file from BuildOutput path -->
   <Where name="/SubExampleA">
     <Item what="/a.txt"                                                              path="BuildOutput"/> -->
     <Item what="/subb/b.txt"                                                         path="BuildOutput"/> -->
   </Where>

   <!-- ************ Copy 1 specific file from specific path -->
   <Where name="/SubExampleB">
     <Item what="/home/developer/PycharmProjects/pythonProject/CopyToDeliveryRepoGitHub/CopyToDeliveryExampleSource/b.txt"     path="full"/>
   </Where>

   <!-- ************ Copy folder with content -->
   <Where name="/">
     <Item what="/home/developer/PycharmProjects/pythonProject/CopyToDeliveryRepoGitHub/CopyToDeliveryExampleSource/subc/*"    path="full"/>
   </Where>

   <!-- ************ Copy multiple files -->
   <Where name="/SubExampleA">
     <Item what="/home/developer/PycharmProjects/pythonProject/CopyToDeliveryRepoGitHub/CopyToDeliveryExampleSource/suba/*.xml"        path="full"/>
   </Where>

   <!-- ************ Copy and rename one specific file -->
   <Where name="/SubExampleA/a_renamed_#VARIANT_LETTER.txt">
     <Item what="/home/developer/PycharmProjects/pythonProject/CopyToDeliveryRepoGitHub/CopyToDeliveryExampleSource/c.txt"            file="rename"/>
   </Where>

 </CopySet>
</MainNode>



